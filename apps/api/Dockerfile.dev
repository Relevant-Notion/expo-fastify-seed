FROM node:22-slim

# Enable corepack and activate the exact pnpm version from package.json
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Copy workspace config files for dependency resolution
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy package.json files for workspace packages the API needs
COPY apps/api/package.json apps/api/package.json
COPY packages/shared/package.json packages/shared/package.json

# Install dependencies (this layer is cached unless lockfile/package.json change)
# Skip prepare script since we don't need git hooks in Docker
RUN pnpm install --ignore-scripts

# Copy the entrypoint script
COPY apps/api/entrypoint.dev.sh apps/api/entrypoint.dev.sh
RUN chmod +x apps/api/entrypoint.dev.sh

# Source code is volume-mounted at runtime for hot reload
# No COPY of source files needed

ENTRYPOINT ["apps/api/entrypoint.dev.sh"]
